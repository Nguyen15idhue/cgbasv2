# CGBAS API
AK=your-access-key
SK=your-secret-key
API_BASE_URL=http://your-cgbas-api-url

# MySQL Database
DB_HOST=mysql
DB_USER=cgbas
DB_PASS=your-password
DB_NAME=cgbas_db

# Session Secret
SESSION_SECRET=change-this-to-random-string-in-production

# eWelink Config (optional - OAuth)
# EWELINK_APPID=your-app-id
# EWELINK_APPSECRET=your-app-secret
# EWELINK_TOKEN=your-token
# EWELINK_REFRESHTOKEN=your-refresh-token
# EWELINK_API=https://as-apia.coolkit.cc

# Onocoy API Hub (optional)
# ONO_USERNAME=your-username
# ONO_PASSWORD=your-password

# Telegram Notification (optional)
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
